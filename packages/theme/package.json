{
  "name": "@jspsych/docusaurus-theme",
  "version": "0.2.0",
  "description": "Shared Docusaurus theme for jsPsych ecosystem documentation sites",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./components": {
      "types": "./lib/components/index.d.ts",
      "default": "./lib/components/index.js"
    },
    "./css/jspsych.css": "./css/jspsych.css",
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "src",
    "css",
    "static"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node scripts/copyUntypedFiles.mjs",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "gen:brain": "node scripts/gen-brain.mjs assets/jspsych-logo-no-text.svg src/components/JspsychBrain/index.tsx"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@docusaurus/theme-common": "3.9.2",
    "@docusaurus/utils-validation": "3.9.2",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@uiw/react-codemirror": "^4.25.10",
    "clsx": "^2.0.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/theme-classic": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "@types/react": "^19.0.0",
    "typescript": "~5.6.2"
  },
  "peerDependencies": {
    "@docusaurus/core": "^3.9.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jspsych/jspsych-docs-theme.git",
    "directory": "packages/theme"
  },
  "homepage": "https://github.com/jspsych/jspsych-docs-theme#readme",
  "bugs": {
    "url": "https://github.com/jspsych/jspsych-docs-theme/issues"
  },
  "license": "MIT"
}
